# Cloud provider OAuth credentials
# Create a "Desktop app" OAuth client in each provider's developer console,
# then paste the IDs here and copy this file to .env.local before running.

# Google Drive
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Drive API, Google People API (or userinfo scope)
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=

# Dropbox
# Console: https://www.dropbox.com/developers/apps
# Redirect URI to add: http://127.0.0.1  (any port — the loopback flow picks an ephemeral one)
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# OneDrive (Microsoft Graph, served via OpenDAL)
# Console: https://entra.microsoft.com → App registrations → New registration
# Platform "Mobile and desktop applications", redirect URI: http://localhost
# Delegated API permissions: Files.ReadWrite.All, offline_access, User.Read
# Leave the secret blank for a public/native app (recommended).
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# S3 and IPFS need no env vars — their credentials/endpoint are entered in the
# in-app connect form (S3 keys, or an IPFS Kubo RPC endpoint) and stored encrypted.
