{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FilDOS",
  "colors": {
    "primary": "#6e9bee",
    "light": "#6e9bee",
    "dark": "#6e9bee"
  },
  "favicon": "/logo/mark-light.svg",
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "introduction",
          "quickstart"
        ]
      },
      {
        "group": "Features",
        "pages": [
          "features/file-management",
          "features/tags",
          "features/ai-search",
          "features/ask-ai",
          "features/canvas",
          "features/cloud-drives"
        ]
      },
      {
        "group": "Under the Hood",
        "pages": [
          "engineering/architecture",
          "engineering/ipc-contract",
          "engineering/ai-pipeline",
          "engineering/data-layer",
          "engineering/testing"
        ]
      },
      {
        "group": "Resources",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/mark-light.svg",
    "dark": "/logo/mark-dark.svg",
    "href": "https://github.com/ahmedfahim21/FilDOS"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0f1117"
    },
    "decoration": "windows"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/ahmedfahim21/FilDOS"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://github.com/ahmedfahim21/FilDOS/releases"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/ahmedfahim21/FilDOS"
    }
  },
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "errors": {
    "404": {
      "redirect": true
    }
  }
}
